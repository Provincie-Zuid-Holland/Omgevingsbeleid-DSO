{% extends "ow/ow_base.xml" %}

{% block content %}
{% for ow_object in ow_objects %}
  <sl:stand>
    <ow-dc:owObject>
        <vt:Hoofdlijn>
            <!-- {{ ow_object.object_status.value }} -->
            {% if ow_object.is_deleted() %}
            <ow:status>{{ ow_object.get_deleted_status() }}</ow:status>
            {% endif %}
            {% if procedure_status is not none %}
            <ow:procedurestatus>{{ procedure_status }}</ow:procedurestatus>
            {% endif %}
            <vt:identificatie>{{ ow_object.identification }}</vt:identificatie>
            <vt:soort>{{ ow_object.hoofdlijn_type }}</vt:soort>
            <vt:naam>{{ ow_object.title }}</vt:naam>
        </vt:Hoofdlijn>
    </ow-dc:owObject>
  </sl:stand>
{% endfor %}
{% endblock %}